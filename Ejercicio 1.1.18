Elabore un algoritmo que calcule el cociente de dos enteros F y G y el Resto de la operación, empleando sólo las operaciones suma y diferencia.

- Análisis previo:
  Edge cases:
    1. F > G
    2. F < G --> cociente = 0; resto  = F;
    3. F = 0 --> cociente = 0; resto = 0
    4. F = G --> cociente = 1; resto = 0
    5. G = 0 --> no es posible realizar la operación. Cociente indefinido

- Datos de entrada:
  + F (dividendo) y G (divisor) --> entero

- Datos de salida:
  + Cociente (de poder realizarse la división) --> entero
  + Resto --> entero

ACCION ejercicio1_1_18 ES

  AMBIENTE

    F, G, resto, cociente: entero;

    PROCESO

      cociente := 0;

      ESC("Ingrese un dividendo: "), LEER(F);
      ESC("Ingrese un divisor distinto de cero: "), LEER(G):

      SI (G > 0) ENTONCES
        SI (F = 0) ENTONCES
          cociente := 0;
          resto := 0;
        SINO
          SI (F = G) ENTONCES
            cociente := 1;
            resto := 0;
          SINO
            SI (F > G) ENTONCES
              MIENTRAS (F >= G) HACER
                F := F - G;
                cociente := cociente + 1;
              FIN_MIENTRAS;
              resto := F;
            SINO
              cociente := 0;
              resto := F;
            FIN_SI;
          FIN_SI;
        FIN_SI;
        ESC("El cociente es: ", cociente);
        ESC("El resto es: ", resto);
      SINO
        ESC("No aplica. El divisor debe de ser mayor que cero.")
      FIN_SI;

    FIN_PROCESO;

FIN_ACCION;









