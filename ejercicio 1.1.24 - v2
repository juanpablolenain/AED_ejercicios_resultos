ACCION ejercicio1_1_24_v_2 ES

  AMBIENTE

    importe, impuesto, valor_cuota: real;

    PROCESO

      ESC("Ingrese el importe: "), LEER(importe);
      MIENTRAS (importe != 9999) HACER
        
        impuesto := (importe/100) * 10

        SI (importe > 500) Y (importe =< 1000) ENTONCES
          valor_cuota := impuesto / 2;
          ESC ("Usted debe pagar un impuesto de: $", impuesto, " en 2 cuotas de: $", valor_cuota);
        SINO
          SI (importe > 1000) ENTONCES
            valor_cuota := impuesto / 3;
            ESC ("Usted debe pagar un impuesto de: $", impuesto, " en 3 cuotas de: $", valor_cuota);
          SINO
            ESC ("Usted debe pagar un impuesto de: $", impuesto, " en una sola cuota);
          FIN_SI;
        FIN_SI;

        ESC("Ingrese el importe: "), LEER(importe);
        
      FIN_MIENTRAS;
